// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash  String?
  name          String?
  oauthProvider String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  resumes       Resume[]

  @@map("users")
}

model Resume {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  title     String
  templateId String  // e.g., "classic-chronological", "modern-sidebar"

  // JSON blob storing all resume content
  data      Json     @default("{\"contact\":{},\"summary\":\"\",\"experience\":[],\"education\":[],\"skills\":[],\"projects\":[],\"certifications\":[],\"customSections\":[]}")

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([userId])
  @@map("resumes")
}
